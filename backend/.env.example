SUPABASE_URL=https://your-project-ref.supabase.co

# Reference variables — documented for shared project parity; not directly read by the backend client
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key
SUPABASE_ANON_KEY=your-supabase-anon-key

# The key the backend client actually uses. Set to your service role key in production.
SUPABASE_KEY=your-supabase-service-role-key

# Optional — retained for reference. JWT verification uses Supabase JWKS (ES256); this value is not used.
SUPABASE_JWT_SECRET=<your-jwt-secret>

# CORS: CORS_ALLOWED_ORIGINS takes priority over ALLOWED_ORIGINS when both are set.
# Production: set CORS_ALLOWED_ORIGINS to your production domain(s).
# ALLOWED_ORIGINS is required and serves as the fallback when CORS_ALLOWED_ORIGINS is absent.
ALLOWED_ORIGINS=http://localhost:3000
CORS_ALLOWED_ORIGINS=http://localhost:3000,https://yourdomain.com

# Optional — rate limit for auth endpoints. Default: 5/minute. Format: <count>/<second|minute|hour|day>
RATE_LIMIT_AUTH=5/minute

# ── AI Search (F15) ──────────────────────────────────────────────────────────

# LLM — query parsing + summary generation
# LLM_PROVIDER: anthropic | openai | openai_compatible (default: anthropic)
LLM_PROVIDER=
LLM_API_KEY=
LLM_MODEL=
# LLM_BASE_URL: required when LLM_PROVIDER=openai_compatible (e.g. https://api.deepseek.com)
LLM_BASE_URL=
# Examples:
#   DeepSeek:  LLM_PROVIDER=openai_compatible  LLM_BASE_URL=https://api.deepseek.com  LLM_MODEL=deepseek-v4-flash
#   Anthropic: LLM_PROVIDER=anthropic           LLM_MODEL=claude-3-5-haiku-latest
#   OpenAI:    LLM_PROVIDER=openai              LLM_MODEL=gpt-4o-mini

# Embeddings — OpenAI-compatible embedding endpoint
EMBEDDING_API_KEY=
EMBEDDING_MODEL=
EMBEDDING_BASE_URL=
# Examples:
#   ZhipuAI:   EMBEDDING_MODEL=embedding-3        EMBEDDING_BASE_URL=https://open.bigmodel.cn/api/paas/v4/
#   OpenAI:    EMBEDDING_MODEL=text-embedding-3-small  EMBEDDING_BASE_URL= (leave empty)
